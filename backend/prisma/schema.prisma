// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  username         String   @unique
  fullname         String
  password         String // should be hashed
  semester         Int?
  major            String?
  monthlyAllowance Float?
  residenceType    String? // e.g. "Kos", "Asrama", "Rumah"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transactions    Transaction[]
  analysisResults AnalysisResult[]
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
}

model Merchant {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  location    String?  // Opsional: Berguna untuk relasi spasial di Knowledge Graph
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
}

model PaymentMethod {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  categoryId      String
  merchantId      String
  paymentMethodId String
  date            DateTime @default(now()) // 1.1 Input Tanggal
  amount          Float                    // 1.2 Input Nominal
  description     String?                  // Opsional
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)     // 1.3 Input Kategori
  merchant      Merchant      @relation(fields: [merchantId], references: [id], onDelete: Restrict)     // 1.4 Input Merchant
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict) // 1.5 Input Metode Pembayaran
}

model AnalysisResult {
  id         String   @id @default(uuid())
  userId     String
  resultType String // "APRIORI" or "GRAPH_SUMMARY"
  data       Json // Store JSON with rules, support, confidence, or graph structure mapping
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

